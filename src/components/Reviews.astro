---
interface Review {
  name: string;
  text: string;
  rating: number;
}
interface Props {
  reviews: {
    headline: string;
    items: Review[];
  };
}
const { reviews } = Astro.props;
---
<section class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-navy text-center mb-12">{reviews.headline}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {reviews.items.map((r) => (
        <div class="border border-slate-200 rounded-xl p-6">
          <div class="flex gap-1 mb-3">
            {Array.from({ length: r.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-400 fill-yellow-400" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <p class="text-slate-600 text-sm mb-4">"{r.text}"</p>
          <p class="text-sm font-semibold text-slate-800">{r.name}</p>
        </div>
      ))}
    </div>
  </div>
</section>
