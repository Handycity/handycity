---
interface Step {
  step: string;
  title: string;
  description: string;
  icon: string;
}
interface Props {
  process: {
    headline: string;
    steps: Step[];
  };
}
const { process: proc } = Astro.props;

const iconPaths: Record<string, string> = {
  'phone': '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>',
  'map-pin': '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  'wrench': '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  'check-circle': '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
};
---
<section class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-navy text-center mb-12">{proc.headline}</h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      {proc.steps.map((s, i) => (
        <div class="relative text-center">
          {/* Connector line (hidden on mobile and last item) */}
          {i < proc.steps.length - 1 && (
            <div class="hidden md:block absolute top-6 left-[calc(50%+2rem)] right-[calc(-50%+2rem)] h-px bg-slate-300" />
          )}
          <div class="w-12 h-12 bg-navy text-white rounded-full flex items-center justify-center mx-auto mb-4 relative z-10">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={iconPaths[s.icon] || iconPaths['check-circle']} />
            </svg>
          </div>
          <h3 class="font-semibold text-slate-800 mb-1">{s.title}</h3>
          <p class="text-sm text-slate-600">{s.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
