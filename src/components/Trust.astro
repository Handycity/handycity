---
interface TrustItem {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  trust: {
    headline: string;
    items: TrustItem[];
  };
}

const { trust } = Astro.props;

const iconPaths: Record<string, string> = {
  'award': '<circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>',
  'zap': '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  'piggy-bank': '<path d="M19 5c-1.5 0-2.8 1.4-3 2-3.5-1.5-11-.3-11 5 0 1.8 0 3 2 4.5V20h4v-2h3v2h4v-4c1-.5 1.7-1 2-2h2v-4h-2c0-1-.5-1.5-1-2"/><path d="M2 9.5a1 1 0 1 0 2 0C4 8.7 3.2 8 2.5 8S1 8.7 1 9.5"/>',
  'leaf': '<path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>'
};
---
<section id="ueber-uns" class="bg-white py-16 md:py-24">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Warum Handycity</p>
      <h2 class="mt-3 text-3xl font-bold text-navy md:text-4xl">{trust.headline}</h2>
      <p class="mt-5 max-w-2xl text-base leading-8 text-slate-600 md:text-lg">
        Ein Defekt muss nicht gleich ein neues Gerät bedeuten. Ob Display, Akku, Kamera oder Ladeanschluss:
        wir reparieren wirtschaftlich, schnell und nachvollziehbar. So bleibt Ihr Smartphone im Einsatz und Sie
        behalten Preis, Aufwand und Dauer jederzeit im Blick.
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {trust.items.map((item) => (
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-navy/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-navy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={iconPaths[item.icon] || iconPaths['award']} />
              </svg>
            </div>
            <h3 class="mt-4 text-base font-semibold text-slate-900">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">{item.description}</p>
          </div>
        ))}
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="#preisrechner"
          class="inline-flex items-center justify-center rounded-full bg-navy px-6 py-3.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-navy-light"
        >
          Preischeck starten
        </a>
        <a
          href="#kontakt"
          class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3.5 text-sm font-semibold text-slate-800 transition hover:-translate-y-0.5 hover:border-navy/40 hover:text-navy"
        >
          Kontakt aufnehmen
        </a>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <img src={`${import.meta.env.BASE_URL}images/display-reparatur.jpg`} alt="Display Reparatur bei Handycity" class="h-48 w-full rounded-[1.75rem] object-cover md:h-60" loading="lazy" />
      <img src={`${import.meta.env.BASE_URL}images/kamera-reparatur.jpg`} alt="Kamera Reparatur bei Handycity" class="h-48 w-full rounded-[1.75rem] object-cover md:h-60" loading="lazy" />
      <img src={`${import.meta.env.BASE_URL}images/store-image-in.jpg`} alt="Handycity Geschäft Innenansicht" class="col-span-2 h-56 w-full rounded-[1.75rem] object-cover md:h-72" loading="lazy" />
    </div>
  </div>
</section>
