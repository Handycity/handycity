---
interface FAQItem {
  question: string;
  answer: string;
}
interface Props {
  faq: {
    headline: string;
    items: FAQItem[];
  };
}
const { faq } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---
<section id="faq" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-navy text-center mb-12 lg:text-left">{faq.headline}</h2>
        <div class="space-y-3" x-data="{ active: null }">
          {faq.items.map((item, i) => (
            <div class="border border-slate-200 rounded-xl bg-white overflow-hidden">
              <button
                @click={`active = active === ${i} ? null : ${i}`}
                class="flex items-center justify-between w-full px-6 py-4.5 text-left text-base font-semibold text-slate-800 hover:text-navy transition-colors cursor-pointer md:text-[1.05rem]"
                :aria-expanded={`active === ${i}`}
              >
                <span>{item.question}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4 shrink-0 ml-4 transition-transform"
                  :class={`{ 'rotate-180': active === ${i} }`}
                  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                ><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div x-show={`active === ${i}`} x-collapse x-cloak>
                <div class="px-6 pb-5 text-[0.98rem] text-slate-600 leading-8">
                  {item.answer}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <aside class="lg:sticky lg:top-24">
        <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-slate-50 p-3 shadow-sm shadow-slate-200/60">
          <img
            src={`${baseUrl}images/shop-innen-left.avif`}
            alt="Handycity Innenansicht für Beratung und FAQ"
            width="1024"
            height="768"
            class="h-[300px] w-full rounded-[1.25rem] object-cover sm:h-[360px] lg:h-[560px]"
            loading="lazy"
            decoding="async"
          />
          <div class="px-3 pb-1 pt-3">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Häufige Fragen</p>
            <p class="mt-1 text-sm font-semibold text-slate-900">Antworten rund um Reparatur, Dauer und Garantie</p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  [x-cloak] { display: none !important; }
</style>
