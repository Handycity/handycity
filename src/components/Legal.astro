---
interface Props {
  impressum: { headline: string; content: string };
  datenschutz: { headline: string; content: string };
}
const { impressum, datenschutz } = Astro.props;
---
<!-- Impressum -->
<section id="impressum" class="py-16 md:py-24 bg-white border-t border-slate-200">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="text-2xl font-bold text-navy mb-6">{impressum.headline}</h2>
    <div class="text-sm text-slate-600 leading-relaxed whitespace-pre-line">
      {impressum.content}
    </div>
  </div>
</section>

<!-- Datenschutz -->
<section id="datenschutz" class="py-16 md:py-24 bg-slate-50 border-t border-slate-200">
  <div class="max-w-3xl mx-auto px-4 prose prose-sm prose-slate">
    <h2 class="text-2xl font-bold text-navy mb-6">{datenschutz.headline}</h2>
    <div class="text-sm text-slate-600 leading-relaxed whitespace-pre-line">
      {datenschutz.content}
    </div>
  </div>
</section>
