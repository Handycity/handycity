---
interface ServiceItem {
  name: string;
  description: string;
  icon: string;
  price: string;
  href?: string;
  actionText?: string;
}

interface Props {
  services: {
    headline: string;
    subheadline: string;
    items: ServiceItem[];
  };
}

const { services } = Astro.props;

const iconPaths: Record<string, string> = {
  smartphone: '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>',
  'battery-charging': '<path d="M5 18H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3.19M15 6h2a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-3.19"/><line x1="23" y1="13" x2="23" y2="11"/><polyline points="11 6 7 12 13 12 9 18"/>',
  camera: '<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>',
  'plug-zap': '<path d="M12 2v10"/><path d="M18.4 6.6 12 12l-6.4-5.4"/><path d="M6.8 15.3 12 12l5.2 3.3"/><path d="M12 12v10"/>',
  'volume-2': '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>',
  repeat: '<polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>',
  'shopping-bag': '<path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>',
  truck: '<rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>'
};

const targetMeta: Record<string, { label: string; description: string }> = {
  '#preisrechner': {
    label: 'Reparatur-Check',
    description: 'Modell und Schaden auswaehlen, Richtpreis sofort sehen'
  },
  '#handy-kaufen': {
    label: 'Webshop',
    description: 'Live-Angebote im Handycity Willhaben-Shop entdecken'
  },
  '#kontakt': {
    label: 'Kontakt',
    description: 'Direkt anfragen und persoenliche Rueckmeldung erhalten'
  },
  '#hol-bring-service': {
    label: 'Hol & Bring',
    description: 'Abholung und Rueckgabe in Klagenfurt organisieren'
  },
  '#standort': {
    label: 'Standort',
    description: 'Adresse, Oeffnungszeiten und Route auf einen Blick'
  }
};

const accentStyles = [
  {
    stripe: 'from-navy to-navy-light',
    icon: 'bg-navy text-white',
    chip: 'border border-navy/20 bg-navy/10 text-navy',
    soft: 'bg-navy/8 text-navy'
  },
  {
    stripe: 'from-green to-emerald-500',
    icon: 'bg-green text-white',
    chip: 'border border-green/20 bg-green-light text-green',
    soft: 'bg-green-light/70 text-slate-700'
  },
  {
    stripe: 'from-slate-900 to-slate-700',
    icon: 'bg-slate-900 text-white',
    chip: 'border border-slate-300 bg-slate-100 text-slate-700',
    soft: 'bg-slate-100 text-slate-700'
  },
  {
    stripe: 'from-rose-600 to-navy-light',
    icon: 'bg-navy-light text-white',
    chip: 'border border-navy/20 bg-navy/10 text-navy',
    soft: 'bg-rose-50 text-rose-700'
  }
];

const items = services.items.map((item, index) => {
  const href = item.href || '#kontakt';
  const actionText = item.actionText || 'Mehr erfahren';

  return {
    ...item,
    href,
    actionText,
    target: targetMeta[href] || targetMeta['#kontakt'],
    accent: accentStyles[index % accentStyles.length],
    rank: index + 1
  };
});

const groupedMap = new Map<string, {
  href: string;
  label: string;
  description: string;
  count: number;
  items: typeof items;
  accent: (typeof accentStyles)[number];
}>();

for (const item of items) {
  const existing = groupedMap.get(item.href);
  if (existing) {
    existing.count += 1;
    existing.items.push(item);
    continue;
  }

  groupedMap.set(item.href, {
    href: item.href,
    label: item.target.label,
    description: item.target.description,
    count: 1,
    items: [item],
    accent: accentStyles[groupedMap.size % accentStyles.length]
  });
}

const groupedEntries = [...groupedMap.values()];
const flowSteps = [
  {
    title: 'Bereich waehlen',
    text: 'Starten Sie mit Reparatur-Check, Webshop oder direkter Kontaktaufnahme.'
  },
  {
    title: 'Service antippen',
    text: 'Jede Karte fuehrt Sie ohne Umwege zur passenden Aktion.'
  },
  {
    title: 'Sofort weiter',
    text: 'Preis pruefen, Angebot ansehen oder Anfrage direkt absenden.'
  }
];
---
<section id="services" class="relative overflow-hidden bg-white py-16 md:py-24">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-64 bg-gradient-to-b from-slate-100/80 to-transparent"></div>
  <div class="pointer-events-none absolute -right-24 top-24 h-52 w-52 rounded-full bg-green-light/60 blur-3xl"></div>
  <div class="pointer-events-none absolute -left-24 bottom-12 h-52 w-52 rounded-full bg-navy/10 blur-3xl"></div>

  <div class="relative mx-auto max-w-7xl px-4">
    <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-lg shadow-slate-200/60">
      <div class="grid gap-8 p-6 lg:grid-cols-[1.08fr_0.92fr] lg:p-9">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Service-Navigator</p>
          <h2 class="mt-3 text-3xl font-bold text-navy md:text-4xl">{services.headline}</h2>
          <p class="mt-4 max-w-3xl text-base leading-8 text-slate-600 md:text-lg">{services.subheadline}</p>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            {groupedEntries.map((entry) => (
              <a
                href={entry.href}
                class="group flex items-center justify-between gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-left transition hover:-translate-y-0.5 hover:border-navy/25 hover:bg-white"
              >
                <div>
                  <p class="text-sm font-semibold text-slate-900">{entry.label}</p>
                  <p class="mt-0.5 text-xs text-slate-600">{entry.description}</p>
                </div>
                <span class="inline-flex h-8 min-w-8 items-center justify-center rounded-full bg-white px-2 text-xs font-semibold text-navy shadow-sm shadow-slate-200">
                  {entry.count}
                </span>
              </a>
            ))}
          </div>
        </div>

        <aside class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-5 md:p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">So geht's</p>
          <div class="mt-4 space-y-3">
            {flowSteps.map((step, index) => (
              <div class="rounded-2xl border border-white bg-white p-4 shadow-sm shadow-slate-100">
                <div class="flex items-start gap-3">
                  <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-navy text-xs font-bold text-white">
                    {index + 1}
                  </span>
                  <div>
                    <p class="text-sm font-semibold text-slate-900">{step.title}</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">{step.text}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <a
            href="#preisrechner"
            class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-full bg-navy px-5 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-navy-light"
          >
            Reparatur-Check starten
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
          </a>
        </aside>
      </div>
    </div>

    <div class="mt-8 grid gap-5 lg:grid-cols-3">
      {groupedEntries.map((group) => (
        <article class="overflow-hidden rounded-[1.6rem] border border-slate-200 bg-white shadow-sm shadow-slate-100">
          <div class={`h-1.5 bg-gradient-to-r ${group.accent.stripe}`}></div>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-lg font-semibold text-slate-900">{group.label}</h3>
                <p class="mt-1 text-sm leading-6 text-slate-600">{group.description}</p>
              </div>
              <span class={`inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.15em] ${group.accent.chip}`}>
                {group.count} Services
              </span>
            </div>

            <div class="mt-4 space-y-2">
              {group.items.map((item) => (
                <a
                  href={item.href}
                  class="group/item flex items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-sm transition hover:border-navy/25 hover:bg-white"
                >
                  <span class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-xl ${item.accent.icon}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <Fragment set:html={iconPaths[item.icon] || iconPaths.smartphone} />
                    </svg>
                  </span>
                  <span class="min-w-0 flex-1">
                    <span class="block truncate font-medium text-slate-800">{item.name}</span>
                    {item.price && <span class="block truncate text-xs text-slate-500">{item.price}</span>}
                  </span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-slate-400 transition group-hover/item:translate-x-0.5 group-hover/item:text-navy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-4">
      {items.map((item) => (
        <a
          href={item.href}
          class="group relative flex h-full flex-col overflow-hidden rounded-[1.6rem] border border-slate-200 bg-white p-6 shadow-sm shadow-slate-100 transition hover:-translate-y-1 hover:border-navy/25 hover:shadow-xl hover:shadow-slate-200/70"
        >
          <div class={`absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r ${item.accent.stripe}`}></div>

          <div class="flex items-start justify-between gap-3">
            <div class={`flex h-12 w-12 items-center justify-center rounded-2xl ${item.accent.icon}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={iconPaths[item.icon] || iconPaths.smartphone} />
              </svg>
            </div>
            <span class="inline-flex rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[11px] font-semibold text-slate-600">
              #{item.rank}
            </span>
          </div>

          <h3 class="mt-5 text-lg font-semibold leading-6 text-slate-900">{item.name}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600">{item.description}</p>

          <div class="mt-4 flex flex-wrap gap-2">
            {item.price && (
              <span class={`inline-flex rounded-full px-3 py-1 text-xs font-medium ${item.accent.soft}`}>
                {item.price}
              </span>
            )}
            <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">
              {item.target.label}
            </span>
          </div>

          <div class="mt-auto pt-5">
            <div class="flex items-center justify-between gap-3 rounded-[1.1rem] border border-slate-200 bg-slate-50 px-4 py-3 transition group-hover:border-navy/20 group-hover:bg-white">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500">{item.target.description}</p>
                <p class="mt-1 text-sm font-semibold text-navy">{item.actionText}</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-navy transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
