---
interface ServiceItem {
  name: string;
  description: string;
  icon: string;
  price: string;
  href?: string;
  actionText?: string;
}

interface Props {
  services: {
    headline: string;
    subheadline: string;
    items: ServiceItem[];
  };
}

const { services } = Astro.props;

const iconPaths: Record<string, string> = {
  'smartphone': '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>',
  'battery-charging': '<path d="M5 18H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3.19M15 6h2a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-3.19"/><line x1="23" y1="13" x2="23" y2="11"/><polyline points="11 6 7 12 13 12 9 18"/>',
  'camera': '<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>',
  'plug-zap': '<path d="M12 2v10"/><path d="M18.4 6.6 12 12l-6.4-5.4"/><path d="M6.8 15.3 12 12l5.2 3.3"/><path d="M12 12v10"/>',
  'volume-2': '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>',
  'repeat': '<polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>',
  'shopping-bag': '<path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>',
  'truck': '<rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>'
};

const targetMeta: Record<string, { label: string; description: string }> = {
  '#preisrechner': {
    label: 'Reparatur-Check',
    description: 'Preise, Modelle und Richtwerte sofort ansehen'
  },
  '#handy-kaufen': {
    label: 'Webshop',
    description: 'Direkt zu den aktuellen Handycity-Angeboten'
  },
  '#kontakt': {
    label: 'Kontakt',
    description: 'Anfrage senden oder Beratung starten'
  },
  '#hol-bring-service': {
    label: 'Hol & Bring',
    description: 'Abholung und Rückgabe im Stadtgebiet prüfen'
  },
  '#standort': {
    label: 'Standort',
    description: 'Adresse, Öffnungszeiten und Route ansehen'
  }
};

const accentStyles = [
  {
    bar: 'bg-navy',
    icon: 'bg-navy text-white',
    chip: 'border border-navy/15 bg-navy/10 text-navy',
    subtle: 'bg-navy/6 text-navy'
  },
  {
    bar: 'bg-green',
    icon: 'bg-green text-white',
    chip: 'border border-green/20 bg-green-light text-green',
    subtle: 'bg-green-light text-slate-700'
  },
  {
    bar: 'bg-slate-900',
    icon: 'bg-slate-900 text-white',
    chip: 'border border-slate-200 bg-slate-100 text-slate-700',
    subtle: 'bg-slate-100 text-slate-700'
  },
  {
    bar: 'bg-navy-light',
    icon: 'bg-navy-light text-white',
    chip: 'border border-navy/15 bg-navy/10 text-navy',
    subtle: 'bg-slate-100 text-slate-700'
  }
];

const items = services.items.map((item, index) => {
  const href = item.href || '#kontakt';
  const actionText = item.actionText || 'Mehr erfahren';

  return {
    ...item,
    href,
    actionText,
    target: targetMeta[href] || targetMeta['#kontakt'],
    accent: accentStyles[index % accentStyles.length]
  };
});

const entryPointMap = new Map<string, { href: string; label: string; description: string; count: number }>();

for (const item of items) {
  const current = entryPointMap.get(item.href);
  if (current) {
    current.count += 1;
  } else {
    entryPointMap.set(item.href, {
      href: item.href,
      label: item.target.label,
      description: item.target.description,
      count: 1
    });
  }
}

const entryPoints = [...entryPointMap.values()];
---
<section id="services" class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4">
    <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-50 shadow-sm shadow-slate-200/70">
      <div class="grid gap-8 p-6 lg:grid-cols-[1.02fr_0.98fr] lg:p-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Startpunkt</p>
          <h2 class="mt-3 text-3xl font-bold text-navy md:text-4xl">{services.headline}</h2>
          <p class="mt-4 max-w-2xl text-base leading-8 text-slate-600 md:text-lg">
            {services.subheadline} Wählen Sie einfach Ihren Bedarf und springen Sie direkt zum passenden Bereich der Seite.
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            {entryPoints.map((entry) => (
              <a
                href={entry.href}
                class="inline-flex items-center gap-3 rounded-full border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:-translate-y-0.5 hover:border-navy/25 hover:text-navy"
              >
                <span class="inline-flex h-2.5 w-2.5 rounded-full bg-navy"></span>
                {entry.label}
                <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-semibold text-slate-500">
                  {entry.count}
                </span>
              </a>
            ))}
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {entryPoints.map((entry, index) => {
            const accent = accentStyles[index % accentStyles.length];

            return (
              <a
                href={entry.href}
                class="group rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm shadow-slate-100 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-200/60"
              >
                <div class={`h-1.5 w-16 rounded-full ${accent.bar}`}></div>
                <p class="mt-4 text-lg font-semibold text-slate-900">{entry.label}</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">{entry.description}</p>
                <div class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-navy">
                  Direkt öffnen
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>

    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-4">
      {items.map((item) => (
        <a
          href={item.href}
          class="group relative flex h-full flex-col overflow-hidden rounded-[1.6rem] border border-slate-200 bg-white p-6 shadow-sm shadow-slate-100 transition hover:-translate-y-1.5 hover:border-navy/25 hover:shadow-xl hover:shadow-slate-200/70"
        >
          <div class={`absolute inset-x-0 top-0 h-1.5 ${item.accent.bar}`}></div>

          <div class="flex items-start justify-between gap-4">
            <div class={`flex h-12 w-12 items-center justify-center rounded-2xl ${item.accent.icon}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={iconPaths[item.icon] || iconPaths.smartphone} />
              </svg>
            </div>

            <span class={`inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] ${item.accent.chip}`}>
              {item.target.label}
            </span>
          </div>

          <h3 class="mt-5 min-h-[3.5rem] text-lg font-semibold leading-6 text-slate-900">{item.name}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600">{item.description}</p>

          <div class="mt-5 flex flex-wrap gap-2">
            {item.price && (
              <span class={`inline-flex rounded-full px-3 py-1 text-xs font-medium ${item.accent.subtle}`}>
                {item.price}
              </span>
            )}
            <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">
              Springt zu {item.target.label}
            </span>
          </div>

          <div class="mt-auto pt-5">
            <div class="flex items-center justify-between gap-3 rounded-[1.1rem] border border-slate-200 bg-slate-50 px-4 py-3 transition group-hover:border-navy/20 group-hover:bg-white">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500">{item.target.description}</p>
                <p class="mt-1 text-sm font-semibold text-navy">{item.actionText}</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-navy transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
