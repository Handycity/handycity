---
interface Props {
  company: {
    name: string;
    address: { street: string; city: string; zip: string };
    geo: { lat: number; lng: number };
  };
  hours: { day: string; time: string; shortDay: string }[];
}
const { company, hours } = Astro.props;
const mapsQuery = encodeURIComponent(`${company.name}, ${company.address.street}, ${company.address.zip} ${company.address.city}`);
const mapsDirections = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${company.address.street}, ${company.address.zip} ${company.address.city}`)}`;
---
<section id="standort" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-navy text-center mb-12">Standort & Öffnungszeiten</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Map -->
      <div class="rounded-xl overflow-hidden border border-slate-200 min-h-[300px] bg-slate-100">
        <iframe
          src={`https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2764.5!2d${company.geo.lng}!3d${company.geo.lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2z${company.address.street}!5e0!3m2!1sde!2sat&q=${mapsQuery}`}
          width="100%"
          height="300"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Google Maps – Handycity Standort"
        ></iframe>
      </div>

      <!-- Info -->
      <div class="space-y-6">
        <div>
          <h3 class="font-semibold text-slate-800 mb-2">Adresse</h3>
          <p class="text-slate-600">
            {company.name}<br />
            {company.address.street}<br />
            {company.address.zip} {company.address.city}
          </p>
          <a
            href={mapsDirections}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm text-cyan hover:underline mt-2"
          >
            Route planen
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>

        <div>
          <h3 class="font-semibold text-slate-800 mb-2">Öffnungszeiten</h3>
          <div class="space-y-1">
            {hours.map((h) => (
              <div class="flex justify-between text-sm">
                <span class="text-slate-600">{h.day}</span>
                <span class={`font-medium ${h.time === 'Geschlossen' ? 'text-slate-400' : 'text-slate-800'}`}>{h.time}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
