---
interface ServiceItem { name: string; description: string; icon: string; price: string; }
interface Props {
  services: { headline: string; subheadline: string; items: ServiceItem[]; };
}

const { services } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const chipEmojiMap: Record<string, string> = {
  'smartphone': '📱',
  'battery-charging': '🔋',
  'camera': '📸',
  'plug-zap': '🔌',
  'volume-2': '🔊',
  'shopping-bag': '🛍️',
};

const intents = [
  {
    key: 'repair',
    title: 'Reparieren',
    emoji: '🔧',
    gradient: 'from-navy to-navy-light',
    href: '#preisrechner',
    cta: 'Preis checken',
    tagline: 'Display, Akku, Kamera & mehr — Preis sofort ausrechnen.',
    icons: ['smartphone', 'battery-charging', 'camera', 'plug-zap', 'volume-2'],
    cardClass: 'group relative flex flex-col overflow-hidden rounded-2xl p-5 md:p-6 bg-white border border-slate-200 hover:border-transparent hover:ring-2 hover:ring-navy/35 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 focus:outline-none focus-visible:ring-4 focus-visible:ring-navy/35',
  },
  {
    key: 'buy',
    title: 'Handy kaufen',
    emoji: '🛍️',
    gradient: 'from-slate-700 to-amber-500',
    href: 'https://www.willhaben.at/iad/shop/handycity-ak-gmbh',
    cta: 'Angebote ansehen',
    tagline: 'Neu, refurbed oder gebraucht kaufen sowie Geräte eintauschen oder zum Ankauf anfragen - im Shop und auf Willhaben.',
    icons: ['shopping-bag'],
    customChips: [
      { emoji: '🔁', label: 'Eintauschen' },
      { emoji: '💶', label: 'Ankauf' },
      { emoji: '✨', label: 'Neu' },
      { emoji: '♻️', label: 'Refurbed' },
      { emoji: '📦', label: 'Gebraucht' },
    ],
    cardClass: 'group relative flex flex-col overflow-hidden rounded-2xl p-5 md:p-6 bg-white border border-slate-200 hover:border-transparent hover:ring-2 hover:ring-amber-400/45 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 focus:outline-none focus-visible:ring-4 focus-visible:ring-amber-400/45',
  },
] as const;

const cards = intents.map((intent) => {
  const chips = [
    ...intent.icons
    .map((icon) => {
      const item = services.items.find((service) => service.icon === icon);
      return item
        ? {
            icon,
            emoji: chipEmojiMap[icon] ?? '🔧',
            label: item.name,
          }
        : null;
    })
    .filter((chip): chip is { icon: string; emoji: string; label: string } => chip !== null),
    ...((intent as { customChips?: { emoji: string; label: string }[] }).customChips ?? []).map((chip) => ({
      icon: chip.label,
      emoji: chip.emoji,
      label: chip.label,
    })),
  ];

  return {
    ...intent,
    chips,
  };
});
---
<section id="services" class="py-12 md:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <aside class="order-2 lg:order-1">
        <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-slate-50 p-3 shadow-sm shadow-slate-200/60">
          <img
            src={`${baseUrl}images/shop-innen-right.avif`}
            alt="Handycity Servicebereich im Shop"
            width="1024"
            height="768"
            class="h-[300px] w-full rounded-[1.25rem] object-cover sm:h-[360px] lg:h-[465px]"
            loading="lazy"
            decoding="async"
          />
          <div class="px-3 pb-1 pt-3">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Interaktive Service-Navigation</p>
            <p class="mt-1 text-sm font-semibold text-slate-900">Schnell zum passenden Service</p>
          </div>
        </div>
      </aside>

      <div class="order-1 lg:order-2">
        <div class="flex items-end justify-between gap-4 mb-6 md:mb-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-navy flex items-center gap-2">
              {services.headline}
              <span aria-hidden="true">👋</span>
            </h2>
            <p class="mt-2 text-sm md:text-base text-slate-600">Wähle, was du brauchst — ein Klick genügt.</p>
          </div>

          <a
            href="#kontakt"
            class="hidden md:inline-flex items-center gap-1.5 text-sm font-semibold text-navy hover:text-navy-light transition-colors"
          >
            Beratung
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="grid grid-cols-1 gap-4 md:gap-5 auto-rows-fr">
          {cards.map((card) => (
            <a href={card.href} class={`${card.cardClass} h-full min-h-[14rem]`}>
              <span class={`absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r ${card.gradient}`}></span>

              <div class="flex h-full flex-col gap-4">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div class="flex items-start gap-3">
                    <span
                      class={`inline-flex w-10 h-10 items-center justify-center rounded-xl bg-gradient-to-br ${card.gradient} text-white text-lg shadow-md group-hover:scale-110 group-hover:-rotate-6 transition-transform duration-300`}
                      aria-hidden="true"
                    >
                      {card.emoji}
                    </span>

                    <div>
                      <h3 class="text-lg md:text-xl font-bold text-slate-900">{card.title}</h3>
                      <p class="mt-1 text-sm text-slate-600 leading-snug">{card.tagline}</p>
                    </div>
                  </div>

                  <div class="flex flex-wrap gap-1.5 lg:max-w-[14rem] lg:justify-end">
                    {card.chips.map((chip) => (
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-slate-100 text-slate-700 text-xs font-medium">
                        <span aria-hidden="true">{chip.emoji}</span>
                        <span>{chip.label}</span>
                      </span>
                    ))}
                  </div>
                </div>

                <div class="mt-auto border-t border-slate-100 pt-3 flex items-center gap-3">
                  <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-900">
                    {card.cta}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M5 12h14" />
                      <path d="m13 5 7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="md:hidden mt-6 text-center text-sm">
          <a href="#kontakt" class="font-medium text-navy hover:text-navy-light transition-colors">Nicht sicher? Wir beraten dich →</a>
        </div>
      </div>
    </div>
  </div>
</section>
