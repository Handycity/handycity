---
interface Props {
  contact: {
    headline: string;
    subheadline: string;
    fields: { name: string; label: string; type: string; required: boolean }[];
  };
  company: {
    phone: string;
    phoneDisplay: string;
    email: string;
  };
}
const { contact, company } = Astro.props;
const mailtoEmail = company.email;
---
<section id="kontakt" class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-3">{contact.headline}</h2>
      <p class="text-slate-600">{contact.subheadline}</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Contact Info -->
      <div class="space-y-6">
        <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="flex items-center gap-4 p-4 border border-slate-200 rounded-xl bg-white hover:border-cyan transition-colors">
          <div class="w-10 h-10 bg-cyan/10 rounded-lg flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <div class="text-xs text-slate-500">Telefon</div>
            <div class="font-semibold text-slate-800">{company.phoneDisplay}</div>
          </div>
        </a>
        <a href={`mailto:${company.email}`} class="flex items-center gap-4 p-4 border border-slate-200 rounded-xl bg-white hover:border-cyan transition-colors">
          <div class="w-10 h-10 bg-cyan/10 rounded-lg flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <div class="text-xs text-slate-500">E-Mail</div>
            <div class="font-semibold text-slate-800">{company.email}</div>
          </div>
        </a>
        <div class="p-4 border border-slate-200 rounded-xl bg-white">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 bg-cyan/10 rounded-lg flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="text-xs text-slate-500">Besuchen Sie uns</div>
              <div class="font-semibold text-slate-800 text-sm">Mo–Fr 09:00–18:00, Sa 09:00–13:00</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Form -->
      <form
        class="space-y-4"
        data-email={mailtoEmail}
        x-data="contactForm()"
        @submit.prevent="submitForm($el)"
      >
        {contact.fields.map((f) => (
          <div>
            <label for={f.name} class="block text-sm font-medium text-slate-700 mb-1">{f.label}{f.required && <span class="text-red-500"> *</span>}</label>
            {f.type === 'textarea' ? (
              <textarea
                id={f.name}
                name={f.name}
                rows="4"
                required={f.required}
                class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-cyan/50 focus:border-cyan transition-colors"
              />
            ) : (
              <input
                type={f.type}
                id={f.name}
                name={f.name}
                required={f.required}
                class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-cyan/50 focus:border-cyan transition-colors"
              />
            )}
          </div>
        ))}

        <div x-show="sent" x-cloak class="text-sm text-green font-medium bg-green-light/50 rounded-lg px-4 py-3">
          Ihr E-Mail-Programm wurde geöffnet. Bitte senden Sie die E-Mail ab, um Ihre Anfrage zu übermitteln.
        </div>

        <button
          type="submit"
          class="w-full bg-navy text-white px-6 py-3 rounded-lg font-semibold hover:bg-navy-light transition-colors cursor-pointer"
        >
          Nachricht senden
        </button>

        <p class="text-xs text-slate-400 text-center">Öffnet Ihr E-Mail-Programm mit den ausgefüllten Daten</p>
      </form>
    </div>
  </div>
</section>

<script>
  import Alpine from 'alpinejs';

  Alpine.data('contactForm', () => ({
    sent: false,

    submitForm(formEl: HTMLFormElement) {
      const data = new FormData(formEl);
      const email = formEl.dataset.email || '';
      const name = data.get('name') || '';
      const device = data.get('device') || '';
      const userEmail = data.get('email') || '';
      const message = data.get('message') || '';

      const subject = encodeURIComponent(`Reparaturanfrage von ${name}${device ? ' – ' + device : ''}`);
      const body = encodeURIComponent(
        `Name: ${name}\n` +
        `E-Mail: ${userEmail}\n` +
        (device ? `Gerät: ${device}\n` : '') +
        `\nNachricht:\n${message}`
      );

      window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
      this.sent = true;
    },
  }));
</script>

<style>
  [x-cloak] { display: none !important; }
</style>
