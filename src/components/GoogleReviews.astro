---
/**
 * Google Reviews section with rating stars and link to Google Business Profile
 */
interface Review {
  name: string;
  text: string;
  rating: number;
  date: string;
}
interface Props {
  reviews: {
    headline: string;
    googleUrl: string;
    averageRating: number;
    totalReviews: number;
    items: Review[];
  };
}
const { reviews } = Astro.props;
const hasReviewItems = reviews.items.length > 0;
---
<section id="bewertungen" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">{reviews.headline}</h2>
      <!-- Aggregate rating -->
      <div class="inline-flex items-center gap-3 bg-slate-50 border border-slate-200 rounded-full px-5 py-2.5">
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class={`w-5 h-5 ${i < Math.round(reviews.averageRating) ? 'text-yellow-400 fill-yellow-400' : 'text-slate-300 fill-slate-300'}`}
              viewBox="0 0 24 24"
            ><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          ))}
        </div>
        <span class="text-lg font-bold text-slate-800">{reviews.averageRating}</span>
        <span class="text-sm text-slate-500">({reviews.totalReviews} Bewertungen)</span>
        <a
          href={reviews.googleUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-2 inline-flex items-center gap-1 text-sm font-medium text-navy hover:underline"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Google
        </a>
      </div>
    </div>

    <!-- Review cards -->
    {hasReviewItems ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {reviews.items.map((r) => (
          <div class="border border-slate-200 rounded-xl p-6 bg-slate-50/50">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-9 h-9 bg-navy/10 rounded-full flex items-center justify-center">
                <span class="text-sm font-bold text-navy">{r.name.charAt(0)}</span>
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-800">{r.name}</p>
                <p class="text-xs text-slate-400">{r.date}</p>
              </div>
            </div>
            <div class="flex gap-0.5 mb-3">
              {Array.from({ length: r.rating }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-yellow-400 fill-yellow-400" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <p class="text-sm text-slate-600 leading-relaxed">"{r.text}"</p>
          </div>
        ))}
      </div>
    ) : (
      <div class="mx-auto max-w-2xl text-center bg-slate-50 border border-slate-200 rounded-xl px-6 py-8 text-slate-600">
        Google-Bewertungen werden direkt von Google geladen. Sobald die API-Zugangsdaten gesetzt sind, erscheinen hier die echten Bewertungen.
      </div>
    )}

    <!-- CTA to Google -->
    <div class="text-center mt-8">
      <a
        href={reviews.googleUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium text-navy hover:underline"
      >
        Alle Bewertungen auf Google ansehen
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </div>
</section>
