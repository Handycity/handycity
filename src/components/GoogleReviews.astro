---
interface Review {
  name: string;
  text: string;
  rating: number;
  date: string;
}

interface Props {
  reviews: {
    headline: string;
    googleUrl: string;
    averageRating: number;
    totalReviews: number;
    items: Review[];
  };
}

const { reviews } = Astro.props;
const averageRating = Number(reviews.averageRating || 0);
const totalReviews = Number(reviews.totalReviews || 0);
const reviewItems = Array.isArray(reviews.items) ? reviews.items.filter((item) => item?.text) : [];
const hasAggregateRating = averageRating > 0 && totalReviews > 0;
const hasReviewItems = reviewItems.length > 0;
const reviewItemsJson = JSON.stringify(reviewItems).replace(/</g, '\\u003c');
const carouselState = `{
  reviews: ${reviewItemsJson},
  activeIndex: 0,
  autoplayMs: 5800,
  timer: null,

  init() {
    if (this.reviews.length > 1) this.startAutoplay();
  },

  next() {
    if (!this.reviews.length) return;
    this.activeIndex = (this.activeIndex + 1) % this.reviews.length;
  },

  prev() {
    if (!this.reviews.length) return;
    this.activeIndex = (this.activeIndex - 1 + this.reviews.length) % this.reviews.length;
  },

  goTo(index) {
    this.activeIndex = index;
    this.restartAutoplay();
  },

  startAutoplay() {
    this.stopAutoplay();
    if (this.reviews.length < 2) return;
    this.timer = setInterval(() => this.next(), this.autoplayMs);
  },

  stopAutoplay() {
    if (!this.timer) return;
    clearInterval(this.timer);
    this.timer = null;
  },

  restartAutoplay() {
    this.startAutoplay();
  }
}`;
---
<section id="bewertungen" class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-navy">{reviews.headline}</h2>
      <p class="mt-4 text-base leading-8 text-slate-600">
        Ausgewählte Google-Rezensionen in einem reduzierten Kartenstil.
      </p>
    </div>

    <div class="mt-8 text-center">
      {hasAggregateRating ? (
        <div class="inline-flex flex-wrap items-center justify-center gap-3 rounded-full border border-slate-200 bg-slate-50 px-5 py-2.5">
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class={`h-5 w-5 ${i < Math.round(averageRating) ? 'fill-yellow-400 text-yellow-400' : 'fill-slate-300 text-slate-300'}`}
                viewBox="0 0 24 24"
              ><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <span class="text-lg font-bold text-slate-800">{averageRating.toFixed(1)}</span>
          <span class="text-sm text-slate-500">({totalReviews} Bewertungen)</span>
          <a
            href={reviews.googleUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="ml-2 inline-flex items-center gap-1 text-sm font-medium text-slate-700 hover:underline"
          >
            <span aria-hidden="true">
              <span class="text-[#4285F4]">G</span><span class="text-[#DB4437]">o</span><span class="text-[#F4B400]">o</span><span class="text-[#4285F4]">g</span><span class="text-[#0F9D58]">l</span><span class="text-[#DB4437]">e</span>
            </span>
          </a>
        </div>
      ) : (
        <div class="mx-auto max-w-2xl rounded-2xl border border-slate-200 bg-slate-50 px-6 py-5 text-sm leading-7 text-slate-600">
          Aktuell sind keine echten Google-Bewertungen gespeichert.
        </div>
      )}
    </div>

    {hasReviewItems ? (
      <div
        x-data={carouselState}
        x-init="init()"
        @mouseenter="stopAutoplay()"
        @mouseleave="startAutoplay()"
        class="mt-10"
      >
        <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-50 p-2 shadow-sm shadow-slate-200/60 md:p-3">
          <div
            class="flex transition-transform duration-700 ease-out"
            :style="`transform: translateX(-${activeIndex * 100}%);`"
          >
            <template x-for="(review, index) in reviews" :key="`${review.name}-${index}`">
              <article class="min-w-full">
                <div class="grid min-h-[240px] gap-6 rounded-[1.5rem] border border-slate-200 bg-white p-5 md:min-h-[220px] md:grid-cols-[240px_minmax(0,1fr)] md:items-center md:p-7">
                  <div class="rounded-[1.25rem] border border-slate-200 bg-slate-50 p-5">
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-[11px] font-semibold tracking-[0.18em] text-slate-500 shadow-sm ring-1 ring-slate-200">
                          <span aria-hidden="true">
                            <span class="text-[#4285F4]">G</span><span class="text-[#DB4437]">o</span><span class="text-[#F4B400]">o</span><span class="text-[#4285F4]">g</span><span class="text-[#0F9D58]">l</span><span class="text-[#DB4437]">e</span>
                          </span>
                          Rezension
                        </span>
                      </div>

                      <div class="flex h-11 w-11 items-center justify-center rounded-full bg-slate-200 text-sm font-semibold uppercase text-slate-700" x-text="review.name.charAt(0)"></div>
                    </div>

                    <div class="mt-4 flex gap-1">
                      <template x-for="star in 5" :key="star">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-4 w-4"
                          :class="star <= review.rating ? 'fill-yellow-400 text-yellow-400' : 'fill-slate-300 text-slate-300'"
                          viewBox="0 0 24 24"
                        >
                          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                        </svg>
                      </template>
                    </div>

                    <div class="mt-5">
                      <p class="text-base font-semibold text-slate-900" x-text="review.name"></p>
                      <p class="mt-1 text-sm text-slate-500" x-text="review.date"></p>
                    </div>
                  </div>

                  <div class="flex items-center">
                    <blockquote class="max-w-3xl text-base leading-8 text-slate-700 md:text-[1.2rem]" x-text="review.text"></blockquote>
                  </div>
                </div>
              </article>
            </template>
          </div>
        </div>

        <div class="mt-5 flex flex-wrap items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <template x-for="(review, index) in reviews" :key="`${review.name}-dot-${index}`">
              <button
                type="button"
                @click="goTo(index)"
                class="h-2 rounded-full transition-all"
                :class="activeIndex === index ? 'w-8 bg-[#4285F4]' : 'w-2 bg-slate-300 hover:bg-slate-400'"
                :aria-label="`Rezension ${index + 1} anzeigen`"
              ></button>
            </template>
          </div>

          <div class="flex items-center gap-2">
            <button
              type="button"
              @click="prev(); restartAutoplay()"
              class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 transition hover:border-slate-300 hover:text-slate-900"
              aria-label="Vorherige Rezension"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>

            <div class="min-w-[3rem] text-center text-sm text-slate-500">
              <span x-text="activeIndex + 1"></span>
              <span>/</span>
              <span x-text="reviews.length"></span>
            </div>

            <button
              type="button"
              @click="next(); restartAutoplay()"
              class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 transition hover:border-slate-300 hover:text-slate-900"
              aria-label="Nächste Rezension"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        </div>
      </div>
    ) : (
      <div class="mx-auto mt-10 max-w-2xl rounded-2xl border border-slate-200 bg-slate-50 px-6 py-8 text-center text-slate-600">
        Noch keine gespeicherten Rezensionen vorhanden.
      </div>
    )}

    <div class="mt-8 text-center">
      <a
        href={reviews.googleUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium text-navy hover:underline"
      >
        Alle Bewertungen auf Google ansehen
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
      </a>
    </div>
  </div>
</section>
