---
interface PickupStep {
  title: string;
  text: string;
}

interface Props {
  pickup: {
    headline: string;
    description: string;
    badge: string;
    ctaText: string;
    steps: PickupStep[];
  };
}

const { pickup } = Astro.props;
---
<section id="hol-bring-service" class="border-y border-slate-200 bg-slate-50 py-16 md:py-20">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div>
      <span class="inline-flex rounded-full bg-navy/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-navy">
        {pickup.badge}
      </span>
      <h2 class="mt-5 text-3xl font-bold text-navy md:text-4xl">{pickup.headline}</h2>
      <p class="mt-4 max-w-2xl text-base leading-8 text-slate-600">{pickup.description}</p>

      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <a
          href="#kontakt"
          class="inline-flex items-center justify-center rounded-full bg-navy px-6 py-3.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-navy-light"
        >
          {pickup.ctaText}
        </a>
        <a
          href="#preisrechner"
          class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3.5 text-sm font-semibold text-slate-800 transition hover:-translate-y-0.5 hover:border-navy/40 hover:text-navy"
        >
          Preischeck starten
        </a>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {pickup.steps.map((step, index) => (
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-100">
          <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-navy text-sm font-bold text-white">
            {index + 1}
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">{step.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{step.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
