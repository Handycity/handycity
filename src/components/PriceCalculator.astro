---
interface RepairPrice {
  brand: string;
  device: string;
  repair: string;
  price: string;
}

interface Props {
  calculator: {
    headline: string;
    subheadline: string;
    prices: RepairPrice[];
  };
}

const { calculator } = Astro.props;

const progressSteps = [
  { index: 1, label: 'Marke' },
  { index: 2, label: 'Modell' },
  { index: 3, label: 'Reparatur' },
];
---
<section id="preisrechner" class="py-16 md:py-24 bg-white">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-8 md:mb-10">
      <div class="text-4xl animate-bounce-slow" aria-hidden="true">🔧</div>
      <h2 class="mt-3 text-2xl md:text-3xl font-bold text-navy">{calculator.headline}</h2>
      <p class="mt-2 text-slate-600">{calculator.subheadline}</p>
    </div>

    <div
      x-data={`priceCalculator(${JSON.stringify(calculator.prices)})`}
      class="relative bg-white border-2 border-slate-100 rounded-3xl p-6 md:p-10 shadow-lg shadow-slate-200/50 overflow-hidden"
    >
      <div class="absolute -top-12 -right-12 w-32 h-32 bg-navy/5 rounded-full blur-2xl" aria-hidden="true"></div>
      <div class="absolute -bottom-8 -left-8 w-24 h-24 bg-green/5 rounded-full blur-2xl" aria-hidden="true"></div>

      <div class="relative mb-8 md:mb-10">
        <div class="absolute top-5 left-[16%] right-[16%] h-0.5 bg-slate-100">
          <div
            class="h-full bg-navy transition-all duration-300"
            :style="step === 1 ? 'width: 0%' : step === 2 ? 'width: 50%' : 'width: 100%'"
          ></div>
        </div>

        <div class="relative grid grid-cols-3 gap-2">
          {progressSteps.map((item) => (
            <div class="flex flex-col items-center gap-2 text-center">
              <div
                class="h-10 w-10 rounded-full border-2 flex items-center justify-center text-sm font-semibold transition-all duration-300"
                :class={`step > ${item.index}
                  ? 'bg-green border-green text-white scale-110'
                  : step === ${item.index}
                    ? 'bg-navy border-navy text-white scale-110 shadow-md shadow-navy/30'
                    : 'bg-white border-slate-200 text-slate-400'`}
              >
                <template x-if={`step > ${item.index}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12" /></svg>
                </template>
                <template x-if={`step <= ${item.index}`}>
                  <span>{item.index}</span>
                </template>
              </div>
              <span class="text-xs font-medium text-slate-500">{item.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div
        x-show="step === 1"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 translate-y-2"
        x-transition:enter-end="opacity-100 translate-y-0"
      >
        <div class="text-center mb-5">
          <h3 class="text-xl font-bold text-slate-900">Welche Marke hat dein Gerät?</h3>
          <p class="text-sm text-slate-600 mt-1">Wähle deinen Hersteller aus</p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <template x-for="brand in brands" :key="brand">
            <button
              type="button"
              @click="selectBrand(brand)"
              class="border-2 rounded-2xl px-4 py-5 font-medium bg-white hover:-translate-y-1 hover:shadow-md transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-navy/40"
              :class="selectedBrand === brand ? 'border-navy bg-navy/5 text-navy shadow-md shadow-navy/10' : 'border-slate-100 hover:border-navy/40'"
            >
              <div class="mb-2 flex h-8 items-center justify-center">
                <img
                  x-show="brandLogo(brand)"
                  :src="brandLogo(brand)"
                  :alt="brand + ' Logo'"
                  class="h-7 w-auto object-contain"
                  loading="lazy"
                  decoding="async"
                />
                <span x-show="!brandLogo(brand)" class="text-2xl" x-text="brandEmoji(brand)" aria-hidden="true"></span>
              </div>
              <div class="text-sm" x-text="brand"></div>
            </button>
          </template>
        </div>
      </div>

      <div
        x-show="step === 2"
        x-cloak
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 translate-y-2"
        x-transition:enter-end="opacity-100 translate-y-0"
      >
        <button
          type="button"
          @click="goBack(1)"
          class="group inline-flex items-center gap-2 text-sm font-semibold text-navy hover:text-navy-light transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-200 group-hover:-translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
          <span x-text="'← Zurück zu ' + selectedBrand"></span>
        </button>

        <div class="text-center mt-4 mb-5">
          <h3 class="text-xl font-bold text-slate-900">Welches Modell?</h3>
          <p class="text-sm text-slate-600 mt-1" x-text="'Dein ' + selectedBrand + ' Gerät auswählen'"></p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <template x-for="device in devices" :key="device">
            <button
              type="button"
              @click="selectDevice(device)"
              class="border-2 rounded-2xl px-4 py-5 font-medium bg-white hover:-translate-y-1 hover:shadow-md transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-navy/40"
              :class="selectedDevice === device ? 'border-navy bg-navy/5 text-navy shadow-md shadow-navy/10' : 'border-slate-100 hover:border-navy/40'"
            >
              <div class="text-2xl mb-2" aria-hidden="true">📱</div>
              <div class="text-sm" x-text="device"></div>
            </button>
          </template>
        </div>
      </div>

      <div
        x-show="step === 3"
        x-cloak
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 translate-y-2"
        x-transition:enter-end="opacity-100 translate-y-0"
      >
        <button
          type="button"
          @click="goBack(2)"
          class="group inline-flex items-center gap-2 text-sm font-semibold text-navy hover:text-navy-light transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-200 group-hover:-translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
          <span>← Zurück zu Modellwahl</span>
        </button>

        <div class="mt-4 mb-5 flex flex-wrap items-center justify-center gap-2">
          <span class="inline-flex items-center gap-1.5 bg-navy/10 text-navy text-xs font-semibold px-3 py-1 rounded-full">
            <img
              x-show="brandLogo(selectedBrand)"
              :src="brandLogo(selectedBrand)"
              :alt="selectedBrand + ' Logo'"
              class="h-4 w-auto object-contain"
              loading="lazy"
              decoding="async"
            />
            <span x-show="!brandLogo(selectedBrand)" x-text="brandEmoji(selectedBrand)" aria-hidden="true"></span>
            <span x-text="selectedBrand"></span>
          </span>
          <span class="text-slate-400" aria-hidden="true">→</span>
          <span class="inline-flex items-center gap-1.5 bg-navy/10 text-navy text-xs font-semibold px-3 py-1 rounded-full">
            <span aria-hidden="true">📱</span>
            <span x-text="selectedDevice"></span>
          </span>
        </div>

        <div class="text-center mb-5">
          <h3 class="text-xl font-bold text-slate-900">Was sollen wir reparieren?</h3>
          <p class="text-sm text-slate-600 mt-1" x-text="'Hier sind die Preise für dein ' + selectedDevice"></p>
        </div>

        <div class="space-y-3">
          <template x-for="repair in repairs" :key="repair.repair">
            <button
              type="button"
              @click="selectedRepair = repair.repair"
              class="w-full flex items-center justify-between border-2 border-slate-100 rounded-2xl px-5 py-4 bg-white hover:border-navy/30 transition-colors text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-navy/40"
            >
              <div class="inline-flex items-center gap-3 text-slate-900">
                <span class="text-xl" x-text="repairEmoji(repair.repair)" aria-hidden="true"></span>
                <span class="font-medium" x-text="repair.repair"></span>
              </div>
              <span class="text-base font-bold text-navy bg-navy/5 px-4 py-1.5 rounded-full" x-text="repair.price"></span>
            </button>
          </template>
        </div>

        <div class="mt-5 bg-gradient-to-r from-green/5 to-green/10 border-2 border-green/20 rounded-2xl p-5 flex items-start gap-4">
          <div class="text-2xl" aria-hidden="true">💰</div>
          <div>
            <h4 class="font-bold text-green">Geräte-Retter-Prämie: Bis zu 50 % zurück!</h4>
            <p class="text-xs text-slate-600 mt-1">
              Mit der Geräte-Retter-Prämie erhalten Sie bis zu €130 zurück.
              <a href="#geraete-retter-praemie" class="font-semibold text-green hover:underline">Mehr erfahren →</a>
            </p>
          </div>
        </div>

        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <a
            href="tel:+43463918559"
            class="inline-flex items-center justify-center rounded-xl bg-navy text-white px-6 py-3 font-semibold hover:bg-navy-light transition-colors"
          >
            📞 Jetzt anrufen
          </a>
          <a
            href="#kontakt"
            class="inline-flex items-center justify-center rounded-xl border-2 border-navy text-navy px-6 py-3 font-semibold hover:bg-navy/5 transition-colors"
          >
            ✉️ Reparatur anfragen
          </a>
        </div>
      </div>
    </div>

    <p class="text-xs text-slate-400 text-center mt-4">Alle Preise sind Richtwerte inkl. MwSt. Der endgültige Preis wird nach Diagnose festgelegt.</p>
  </div>
</section>

<script>
  import Alpine from 'alpinejs';

  const brandLogoMap: Record<string, string> = {
    'Apple': '/brands/apple.svg',
    'Samsung': '/brands/samsung.svg',
    'Huawei': '/brands/huawei.svg',
    'Xiaomi': '/brands/xiaomi.svg',
    'OnePlus': '/brands/oneplus.svg',
    'Google': '/brands/google.svg',
    'Sony': '/brands/sony.svg',
    'Nokia': '/brands/nokia.svg',
  };

  const brandEmojiMap: Record<string, string> = {
    'Apple': '🍎', 'Samsung': '📱', 'Huawei': '🌐', 'Xiaomi': '🔧',
    'OnePlus': '⚡', 'Google': '🔍', 'Sony': '🎮', 'Nokia': '📞',
  };

  const repairEmojiMap: Record<string, string> = {
    'Display': '🖥️', 'Akku': '🔋', 'Kamera': '📸',
    'Ladebuchse': '🔌', 'Lautsprecher': '🔊', 'Backcover': '🛡️',
  };

  Alpine.data('priceCalculator', (allPrices) => ({
    allPrices,
    step: 1,
    selectedBrand: '',
    selectedDevice: '',
    selectedRepair: '',
    brandLogo(brand) {
      return brandLogoMap[brand] ?? '';
    },
    brandEmoji(brand)  {
      return brandEmojiMap[brand] ?? '📱';
    },
    repairEmoji(repair){
      const normalizedRepair = String(repair || '').toLowerCase();
      const match = Object.entries(repairEmojiMap).find(([key]) => normalizedRepair.includes(key.toLowerCase()));
      return match ? match[1] : '🔧';
    },
    get brands()  { return [...new Set(this.allPrices.map((p) => p.brand))]; },
    get devices() { return [...new Set(this.allPrices.filter((p) => p.brand === this.selectedBrand).map((p) => p.device))]; },
    get repairs() { return this.allPrices.filter((p) => p.brand === this.selectedBrand && p.device === this.selectedDevice); },
    selectBrand(b)  { this.selectedBrand = b; this.selectedDevice = ''; this.selectedRepair = ''; this.step = 2; },
    selectDevice(d) { this.selectedDevice = d; this.selectedRepair = ''; this.step = 3; },
    goBack(toStep)  {
      if (toStep <= 1) { this.selectedBrand = ''; this.selectedDevice = ''; this.selectedRepair = ''; this.step = 1; }
      else if (toStep <= 2) { this.selectedDevice = ''; this.selectedRepair = ''; this.step = 2; }
    },
  }));
</script>

<style>
  [x-cloak] { display: none !important; }

  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .animate-bounce-slow {
    animation: bounce-slow 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-bounce-slow { animation: none !important; }
  }
</style>
