---
interface RepairPrice {
  brand: string;
  device: string;
  repair: string;
  price: string;
}
interface Props {
  calculator: {
    headline: string;
    subheadline: string;
    prices: RepairPrice[];
  };
}
const { calculator } = Astro.props;
const pricesJson = JSON.stringify(calculator.prices);

const brandEmojis: Record<string, string> = {
  'Apple': '🍎',
  'Samsung': '📱',
  'Huawei': '🌐',
  'Xiaomi': '🔧',
  'OnePlus': '⚡',
  'Google': '🔍',
  'Sony': '🎮',
  'Nokia': '📞',
};

const repairEmojis: Record<string, string> = {
  'Display': '🖥️',
  'Akku': '🔋',
  'Kamera': '📸',
  'Ladebuchse': '🔌',
  'Lautsprecher': '🔊',
  'Backcover': '🛡️',
};
---
<section id="preisrechner" class="py-16 md:py-24 bg-gradient-to-b from-slate-50 to-white">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-10">
      <span class="inline-block text-4xl mb-3 animate-bounce-slow">🔧</span>
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-3">{calculator.headline}</h2>
      <p class="text-slate-600 max-w-lg mx-auto">{calculator.subheadline}</p>
    </div>

    <div
      x-data={`priceCalculator(${pricesJson})`}
      class="relative bg-white border-2 border-slate-100 rounded-3xl p-6 md:p-10 shadow-lg shadow-slate-200/50 overflow-hidden"
    >
      <!-- Decorative corner blobs -->
      <div class="absolute -top-12 -right-12 w-32 h-32 bg-navy/5 rounded-full blur-2xl pointer-events-none"></div>
      <div class="absolute -bottom-8 -left-8 w-24 h-24 bg-green/5 rounded-full blur-2xl pointer-events-none"></div>

      <!-- Progress bar -->
      <div class="relative mb-8">
        <div class="flex items-center justify-between mb-2">
          <template x-for="(label, i) in ['Marke', 'Modell', 'Reparatur']" :key="i">
            <div class="flex flex-col items-center flex-1">
              <div
                class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold transition-all duration-300 border-2"
                :class="step > i + 1 ? 'bg-green border-green text-white scale-110' : step === i + 1 ? 'bg-navy border-navy text-white scale-110 shadow-md shadow-navy/30' : 'bg-white border-slate-200 text-slate-400'"
              >
                <template x-if="step > i + 1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </template>
                <template x-if="step <= i + 1">
                  <span x-text="i + 1"></span>
                </template>
              </div>
              <span class="text-[11px] font-medium mt-1.5 transition-colors" :class="step >= i + 1 ? 'text-slate-700' : 'text-slate-400'" x-text="label"></span>
            </div>
          </template>
        </div>
        <div class="absolute top-5 left-[16%] right-[16%] h-0.5 bg-slate-100 -z-0">
          <div class="h-full bg-navy transition-all duration-500 rounded-full" :style="`width: ${step === 1 ? '0%' : step === 2 ? '50%' : '100%'}`"></div>
        </div>
      </div>

      <!-- Step 1: Brand -->
      <div x-show="step === 1" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
        <p class="text-center text-lg font-semibold text-slate-800 mb-2">Welche Marke hat dein Gerät?</p>
        <p class="text-center text-sm text-slate-500 mb-6">Wähle deinen Hersteller aus</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <template x-for="brand in brands" :key="brand">
            <button
              @click="selectBrand(brand)"
              class="group relative border-2 rounded-2xl px-4 py-5 font-medium text-slate-700 bg-white cursor-pointer transition-all duration-200 hover:-translate-y-1 hover:shadow-md"
              :class="selectedBrand === brand ? 'border-navy bg-navy/5 text-navy shadow-md shadow-navy/10' : 'border-slate-100 hover:border-navy/40'"
            >
              <span class="block text-2xl mb-2" x-text="brandEmoji(brand)"></span>
              <span class="block text-sm" x-text="brand"></span>
            </button>
          </template>
        </div>
      </div>

      <!-- Step 2: Device -->
      <div x-show="step === 2" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
        <button @click="goBack(1)" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-navy cursor-pointer mb-5 group transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          <span>Zurück zu <span class="font-medium" x-text="selectedBrand"></span></span>
        </button>
        <p class="text-center text-lg font-semibold text-slate-800 mb-2">Welches Modell?</p>
        <p class="text-center text-sm text-slate-500 mb-6">Dein <span class="font-medium text-navy" x-text="selectedBrand"></span> Gerät auswählen</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <template x-for="device in devices" :key="device">
            <button
              @click="selectDevice(device)"
              class="group relative border-2 rounded-2xl px-4 py-5 font-medium text-slate-700 bg-white cursor-pointer transition-all duration-200 hover:-translate-y-1 hover:shadow-md"
              :class="selectedDevice === device ? 'border-navy bg-navy/5 text-navy shadow-md shadow-navy/10' : 'border-slate-100 hover:border-navy/40'"
            >
              <span class="block text-2xl mb-2">📱</span>
              <span class="block text-sm" x-text="device"></span>
            </button>
          </template>
        </div>
      </div>

      <!-- Step 3: Repair type + Price -->
      <div x-show="step === 3" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
        <button @click="goBack(2)" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-navy cursor-pointer mb-5 group transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          <span>Zurück zu Modellwahl</span>
        </button>

        <!-- Breadcrumb pills -->
        <div class="flex items-center justify-center gap-2 mb-6">
          <span class="inline-flex items-center gap-1 bg-navy/10 text-navy text-xs font-semibold px-3 py-1 rounded-full">
            <span x-text="brandEmoji(selectedBrand)"></span>
            <span x-text="selectedBrand"></span>
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          <span class="inline-flex items-center gap-1 bg-navy/10 text-navy text-xs font-semibold px-3 py-1 rounded-full">
            📱 <span x-text="selectedDevice"></span>
          </span>
        </div>

        <p class="text-center text-lg font-semibold text-slate-800 mb-2">Was sollen wir reparieren?</p>
        <p class="text-center text-sm text-slate-500 mb-6">Hier sind die Preise für dein <span class="font-medium text-navy" x-text="selectedDevice"></span></p>

        <div class="space-y-3">
          <template x-for="repair in repairs" :key="repair.repair">
            <div class="flex items-center justify-between border-2 border-slate-100 rounded-2xl px-5 py-4 bg-white hover:border-navy/30 transition-colors group">
              <div class="flex items-center gap-3">
                <span class="text-xl" x-text="repairEmoji(repair.repair)"></span>
                <span class="text-sm font-semibold text-slate-700" x-text="repair.repair"></span>
              </div>
              <span class="text-base font-bold text-navy bg-navy/5 px-4 py-1.5 rounded-full" x-text="repair.price"></span>
            </div>
          </template>
        </div>

        <!-- Geräte-Retter-Prämie hint -->
        <div class="mt-6 bg-gradient-to-r from-green/5 to-green/10 border-2 border-green/20 rounded-2xl p-5 flex items-start gap-4">
          <span class="text-2xl shrink-0">💰</span>
          <div>
            <p class="text-sm font-bold text-green">Geräte-Retter-Prämie: Bis zu 50 % zurück!</p>
            <p class="text-xs text-slate-600 mt-1">Mit der Geräte-Retter-Prämie erhalten Sie bis zu €130 zurück. <a href="#geraete-retter-praemie" class="underline font-medium text-green hover:text-green/80">Mehr erfahren →</a></p>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <a href="tel:+43463918559" class="flex-1 inline-flex items-center justify-center gap-2 bg-navy text-white px-5 py-3.5 rounded-xl font-semibold text-sm hover:bg-navy-light transition-all hover:shadow-lg hover:shadow-navy/20 hover:-translate-y-0.5">
            📞 Jetzt anrufen
          </a>
          <a href="#kontakt" class="flex-1 inline-flex items-center justify-center gap-2 border-2 border-navy text-navy px-5 py-3.5 rounded-xl font-semibold text-sm hover:bg-navy/5 transition-all hover:-translate-y-0.5">
            ✉️ Reparatur anfragen
          </a>
        </div>
      </div>
    </div>

    <p class="text-xs text-slate-400 text-center mt-4">Alle Preise sind Richtwerte inkl. MwSt. Der endgültige Preis wird nach Diagnose festgelegt.</p>
  </div>
</section>

<script>
  import Alpine from 'alpinejs';

  const brandEmojiMap: Record<string, string> = {
    'Apple': '🍎',
    'Samsung': '📱',
    'Huawei': '🌐',
    'Xiaomi': '🔧',
    'OnePlus': '⚡',
    'Google': '🔍',
    'Sony': '🎮',
    'Nokia': '📞',
  };

  const repairEmojiMap: Record<string, string> = {
    'Display': '🖥️',
    'Akku': '🔋',
    'Kamera': '📸',
    'Ladebuchse': '🔌',
    'Lautsprecher': '🔊',
    'Backcover': '🛡️',
  };

  Alpine.data('priceCalculator', (allPrices) => ({
    allPrices,
    step: 1,
    selectedBrand: '',
    selectedDevice: '',
    selectedRepair: '',

    brandEmoji(brand: string) {
      return brandEmojiMap[brand] || '📱';
    },

    repairEmoji(repair: string) {
      for (const [key, emoji] of Object.entries(repairEmojiMap)) {
        if (repair.toLowerCase().includes(key.toLowerCase())) return emoji;
      }
      return '🔧';
    },

    get brands() {
      return [...new Set(this.allPrices.map((p: any) => p.brand))];
    },

    get devices() {
      return [...new Set(this.allPrices.filter((p: any) => p.brand === this.selectedBrand).map((p: any) => p.device))];
    },

    get repairs() {
      return this.allPrices.filter((p: any) => p.brand === this.selectedBrand && p.device === this.selectedDevice);
    },

    selectBrand(brand: string) {
      this.selectedBrand = brand;
      this.selectedDevice = '';
      this.selectedRepair = '';
      this.step = 2;
    },

    selectDevice(device: string) {
      this.selectedDevice = device;
      this.selectedRepair = '';
      this.step = 3;
    },

    goBack(toStep: number) {
      if (toStep <= 1) {
        this.selectedBrand = '';
        this.selectedDevice = '';
        this.selectedRepair = '';
        this.step = 1;
      } else if (toStep <= 2) {
        this.selectedDevice = '';
        this.selectedRepair = '';
        this.step = 2;
      }
    },
  }));
</script>

<style>
  [x-cloak] { display: none !important; }
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .animate-bounce-slow { animation: bounce-slow 2s ease-in-out infinite; }
</style>
