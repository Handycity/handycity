---
interface RepairPrice {
  brand: string;
  device: string;
  repair: string;
  price: string;
}

interface Props {
  calculator: {
    headline: string;
    subheadline: string;
    helper: string;
    resultTitle: string;
    note: string;
    ctaPrimaryText: string;
    ctaSecondaryText: string;
    subsidyBadge: string;
    subsidyText: string;
    prices: RepairPrice[];
  };
}

const { calculator } = Astro.props;
const pricesJson = JSON.stringify(calculator.prices);
const calculatorState = `{
  allPrices: ${pricesJson},
  selectedBrand: '',
  selectedDevice: '',
  selectedRepair: '',

  get brands() {
    return [...new Set(this.allPrices.map((item) => item.brand))];
  },

  get devices() {
    return [...new Set(this.allPrices.filter((item) => item.brand === this.selectedBrand).map((item) => item.device))];
  },

  get repairs() {
    return this.allPrices.filter((item) => item.brand === this.selectedBrand && item.device === this.selectedDevice);
  },

  get selectedPrice() {
    const match = this.repairs.find((item) => item.repair === this.selectedRepair);
    return match ? match.price : '';
  },

  get progressWidth() {
    if (!this.selectedBrand) return 10;
    if (!this.selectedDevice) return 45;
    if (!this.selectedRepair) return 78;
    return 100;
  },

  get progressText() {
    if (!this.selectedBrand) return 'Schritt 1 von 3';
    if (!this.selectedDevice) return 'Schritt 2 von 3';
    if (!this.selectedRepair) return 'Schritt 3 von 3';
    return 'Preis gefunden';
  },

  get hasSelection() {
    return Boolean(this.selectedBrand && this.selectedDevice && this.selectedRepair);
  },

  handleBrandChange() {
    this.selectedDevice = '';
    this.selectedRepair = '';
  },

  handleDeviceChange() {
    this.selectedRepair = '';
  },

  handleRepairChange() {
    return;
  }
}`;
---
<section id="preisrechner" class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Preischeck</p>
      <h2 class="mt-3 text-3xl font-bold text-navy md:text-4xl">{calculator.headline}</h2>
      <p class="mt-4 text-base leading-8 text-slate-600 md:text-lg">{calculator.subheadline}</p>
    </div>

    <div
      x-data={calculatorState}
      class="mt-10 grid gap-6 rounded-[2rem] border border-slate-200 bg-slate-50/70 p-6 shadow-xl shadow-slate-100/80 lg:grid-cols-[0.94fr_1.06fr] lg:p-8"
    >
      <div class="rounded-[1.75rem] border border-slate-200 bg-white p-6 lg:p-7">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">Reparatur-Check</p>
            <h3 class="mt-2 text-2xl font-bold text-slate-900">Preis in wenigen Schritten</h3>
          </div>
          <div class="rounded-full bg-navy/10 px-4 py-2 text-xs font-semibold text-navy" x-text="progressText"></div>
        </div>

        <div class="mt-6 h-2 overflow-hidden rounded-full bg-slate-100">
          <div class="h-full rounded-full bg-navy transition-all duration-300" :style="`width: ${progressWidth}%`"></div>
        </div>

        <div class="mt-6 space-y-5">
          <div>
            <label for="brandSelect" class="mb-2 block text-sm font-semibold text-slate-800">1. Marke</label>
            <div class="relative">
              <select
                id="brandSelect"
                x-model="selectedBrand"
                @change="handleBrandChange"
                class="w-full appearance-none rounded-2xl border border-slate-200 bg-white px-4 py-3.5 text-sm text-slate-800 outline-none transition focus:border-navy"
              >
                <option value="">Marke wählen</option>
                <template x-for="brand in brands" :key="brand">
                  <option :value="brand" x-text="brand"></option>
                </template>
              </select>
              <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute right-4 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
          </div>

          <div>
            <label for="deviceSelect" class="mb-2 block text-sm font-semibold text-slate-800">2. Modell</label>
            <div class="relative">
              <select
                id="deviceSelect"
                x-model="selectedDevice"
                @change="handleDeviceChange"
                :disabled="!selectedBrand"
                class="w-full appearance-none rounded-2xl border border-slate-200 bg-white px-4 py-3.5 text-sm text-slate-800 outline-none transition disabled:cursor-not-allowed disabled:bg-slate-50 disabled:text-slate-400 focus:border-navy"
              >
                <option value="">Modell wählen</option>
                <template x-for="device in devices" :key="device">
                  <option :value="device" x-text="device"></option>
                </template>
              </select>
              <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute right-4 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
          </div>

          <div>
            <label for="repairSelect" class="mb-2 block text-sm font-semibold text-slate-800">3. Reparatur</label>
            <div class="relative">
              <select
                id="repairSelect"
                x-model="selectedRepair"
                @change="handleRepairChange"
                :disabled="!selectedDevice"
                class="w-full appearance-none rounded-2xl border border-slate-200 bg-white px-4 py-3.5 text-sm text-slate-800 outline-none transition disabled:cursor-not-allowed disabled:bg-slate-50 disabled:text-slate-400 focus:border-navy"
              >
                <option value="">Reparatur wählen</option>
                <template x-for="repair in repairs" :key="repair.repair">
                  <option :value="repair.repair" x-text="repair.repair"></option>
                </template>
              </select>
              <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute right-4 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-4 text-sm leading-6 text-slate-600">
          {calculator.helper}
        </div>
      </div>

      <aside class="space-y-5">
        <div class="rounded-[1.75rem] bg-navy p-6 text-white shadow-xl shadow-navy/20 lg:p-7">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-white/70">{calculator.resultTitle}</p>

          <div x-show="hasSelection" x-cloak class="mt-4">
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full bg-white/10 px-3 py-1.5 text-xs font-semibold" x-text="selectedBrand || 'Marke'"></span>
              <span class="rounded-full bg-white/10 px-3 py-1.5 text-xs font-semibold" x-text="selectedDevice || 'Modell'"></span>
              <span class="rounded-full bg-white/10 px-3 py-1.5 text-xs font-semibold" x-text="selectedRepair || 'Reparatur'"></span>
            </div>
            <div class="mt-5 rounded-[1.5rem] bg-white/10 p-5">
              <p class="text-sm text-white/70">Aktueller Richtpreis</p>
              <p class="mt-2 text-4xl font-bold" x-text="selectedPrice || 'Preis auf Anfrage'"></p>
              <p class="mt-3 text-sm leading-6 text-white/75">{calculator.note}</p>
            </div>
          </div>

          <div x-show="!hasSelection" class="mt-4 rounded-[1.5rem] bg-white/10 p-5">
            <p class="text-sm text-white/70">Beispiel</p>
            <p class="mt-2 text-3xl font-bold">ab EUR 89</p>
            <p class="mt-3 text-sm leading-6 text-white/75">Für viele Standardreparaturen sehen Sie den Richtpreis sofort. Danach klären wir den finalen Aufwand transparent vor Ort.</p>
          </div>

          <div class="mt-5 grid gap-3 sm:grid-cols-2">
            <a
              href="tel:+43463918559"
              class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-navy transition hover:-translate-y-0.5"
            >
              {calculator.ctaPrimaryText}
            </a>
            <a
              href="#kontakt"
              class="inline-flex items-center justify-center rounded-xl border border-white/20 bg-white/10 px-5 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-white/20"
            >
              {calculator.ctaSecondaryText}
            </a>
          </div>
        </div>

        <div class="rounded-[1.75rem] border border-green/20 bg-green-light/60 p-6">
          <div class="inline-flex rounded-full bg-green px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-white">
            {calculator.subsidyBadge}
          </div>
          <p class="mt-4 text-base font-semibold text-slate-900">{calculator.subsidyText}</p>
          <a href="#geraete-retter-praemie" class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-green hover:underline">
            Mehr zur Förderung
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  [x-cloak] { display: none !important; }
</style>
