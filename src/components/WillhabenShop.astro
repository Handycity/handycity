---
interface Offer {
  title: string;
  price: string;
  url: string;
  image: string;
  imageAlt?: string;
  listedAt?: string;
  storage: string;
  unlocked: string;
  condition: string;
  delivery: string;
  note?: string;
}

interface Props {
  willhaben: {
    headline: string;
    description: string;
    highlights: string[];
    url: string;
    ctaText: string;
    verifiedOn?: string;
    contactCtaText?: string;
    offers?: Offer[];
  };
}

const { willhaben } = Astro.props;
const offers = Array.isArray(willhaben.offers) ? willhaben.offers : [];
const contactCtaText = willhaben.contactCtaText || 'Kontakt';
const syncLabel = willhaben.verifiedOn ? `Live-Sync ${willhaben.verifiedOn}` : 'Regelmaessig synchronisiert';
const baseUrl = import.meta.env.BASE_URL;
---
<section id="handy-kaufen" class="border-y border-slate-200 bg-slate-50 py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4">
    <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm shadow-slate-200/70">
      <div class="grid gap-8 border-b border-slate-200 p-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:p-10">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Willhaben & Shop</p>
          <h2 class="mt-3 text-3xl font-bold text-navy md:text-4xl">{willhaben.headline}</h2>
          <p class="mt-4 max-w-3xl text-base leading-8 text-slate-600">{willhaben.description}</p>

          <div class="mt-6 flex flex-wrap gap-2">
            <div class="inline-flex items-center gap-2 rounded-full border border-navy/15 bg-navy/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-navy">
              {syncLabel}
            </div>
            <div class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-600">
              {offers.length} aktuelle Anzeigen
            </div>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            {willhaben.highlights.map((highlight) => (
              <div class="flex items-start gap-3 rounded-2xl bg-slate-50 px-4 py-3">
                <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-green text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <p class="text-sm leading-6 text-slate-700">{highlight}</p>
              </div>
            ))}
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={willhaben.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-navy px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-navy-light"
            >
              {willhaben.ctaText}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M8 7h9v9"/></svg>
            </a>
            <a
              href="#kontakt"
              class="inline-flex items-center rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 transition hover:-translate-y-0.5 hover:border-navy/40 hover:text-navy"
            >
              {contactCtaText}
            </a>
          </div>
        </div>

        <aside class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-5">
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm shadow-slate-100">
            <img
              src={`${baseUrl}images/willhaben.jpg`}
              alt="Willhaben Shop von Handycity"
              class="h-72 w-full object-cover md:h-[26rem]"
              loading="lazy"
              decoding="async"
            />
            <div class="border-t border-slate-200 px-4 py-3">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Shop Vorschau</p>
              <p class="mt-1 text-sm font-semibold text-slate-900">Handycity auf Willhaben</p>
              <p class="mt-1 text-sm text-slate-600">Angebote, Ankauf und persoenliche Beratung in einem Bereich.</p>
            </div>
          </div>
        </aside>
      </div>

      {offers.length ? (
        <div class="p-6 lg:p-8">
          <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
            {offers.map((offer) => (
              <article class="group flex h-full flex-col overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm shadow-slate-100 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-200/70">
                <a
                  href={offer.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="relative block aspect-[5/4] overflow-hidden bg-slate-100"
                  aria-label={`${offer.title} auf Willhaben ansehen`}
                >
                  <img
                    src={offer.image}
                    alt={offer.imageAlt || offer.title}
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                  />
                  <div class="absolute left-4 top-4 rounded-full bg-white/95 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-700 shadow-sm">
                    Willhaben
                  </div>
                </a>

                <div class="flex flex-1 flex-col p-5">
                  <div class="flex min-h-[2.75rem] flex-wrap gap-2">
                    {offer.listedAt && (
                      <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-medium text-slate-600">
                        Anzeige vom {offer.listedAt}
                      </span>
                    )}
                    <span class="inline-flex items-center rounded-full bg-green-light/55 px-3 py-1 text-[11px] font-medium text-slate-700">
                      {offer.condition}
                    </span>
                    {offer.note && (
                      <span class="inline-flex items-center rounded-full bg-navy/8 px-3 py-1 text-[11px] font-medium text-navy">
                        {offer.note}
                      </span>
                    )}
                  </div>

                  <div class="mt-4 flex items-start justify-between gap-4">
                    <h3 class="min-h-[3.5rem] text-lg font-semibold leading-6 text-slate-900">{offer.title}</h3>
                    <div class="shrink-0 text-right">
                      <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500">Preis</p>
                      <p class="mt-1 text-xl font-bold text-navy">{offer.price}</p>
                    </div>
                  </div>

                  <dl class="mt-5 grid grid-cols-2 gap-3 text-sm">
                    <div class="rounded-2xl bg-slate-50 px-4 py-3">
                      <dt class="text-slate-500">Speicher</dt>
                      <dd class="mt-1 font-semibold text-slate-900">{offer.storage}</dd>
                    </div>
                    <div class="rounded-2xl bg-slate-50 px-4 py-3">
                      <dt class="text-slate-500">Entsperrt</dt>
                      <dd class="mt-1 font-semibold text-slate-900">{offer.unlocked}</dd>
                    </div>
                    <div class="rounded-2xl bg-slate-50 px-4 py-3">
                      <dt class="text-slate-500">Zustand</dt>
                      <dd class="mt-1 font-semibold text-slate-900">{offer.condition}</dd>
                    </div>
                    <div class="rounded-2xl bg-slate-50 px-4 py-3">
                      <dt class="text-slate-500">Uebergabe</dt>
                      <dd class="mt-1 font-semibold text-slate-900">{offer.delivery}</dd>
                    </div>
                  </dl>

                  <div class="mt-5 flex flex-col gap-3 border-t border-slate-200 pt-4 sm:flex-row">
                    <a
                      href={offer.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center justify-center gap-2 rounded-full bg-navy px-5 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-navy-light"
                    >
                      Willhaben oeffnen
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M8 7h9v9"/></svg>
                    </a>
                    <a
                      href="#kontakt"
                      class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-800 transition hover:-translate-y-0.5 hover:border-navy/40 hover:text-navy"
                    >
                      {contactCtaText}
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ) : (
        <div class="px-6 py-10 text-center text-slate-600 lg:px-8">
          <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 px-6 py-10 shadow-sm shadow-slate-100">
            Aktuell konnten keine Willhaben-Angebote geladen werden.
          </div>
        </div>
      )}
    </div>
  </div>
</section>
