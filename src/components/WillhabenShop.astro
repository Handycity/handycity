---
/**
 * Willhaben shop section — links to the Handycity Willhaben store
 */
interface Props {
  willhaben: {
    headline: string;
    description: string;
    url: string;
    ctaText: string;
  };
}
const { willhaben } = Astro.props;
---
<section id="handy-kaufen" class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden md:grid md:grid-cols-2 md:items-center">
      <!-- Image -->
      <div class="h-56 md:h-full">
        <img
          src={`${import.meta.env.BASE_URL}images/store-image-out.png`}
          alt="Handycity Geschäft Außenansicht Klagenfurt"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <!-- Content -->
      <div class="p-8 md:p-10">
        <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">{willhaben.headline}</h2>
        <p class="text-slate-600 mb-6 leading-relaxed">{willhaben.description}</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={willhaben.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-navy text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-navy-light transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            {willhaben.ctaText}
          </a>
          <a
            href="tel:+43463918559"
            class="inline-flex items-center justify-center gap-2 border-2 border-navy text-navy px-6 py-3 rounded-lg font-semibold text-sm hover:bg-navy/5 transition-colors"
          >
            Im Geschäft beraten lassen
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
