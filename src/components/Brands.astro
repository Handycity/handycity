---
interface Props {
  brands: {
    headline: string;
    items: string[];
  };
}
const { brands } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const brandLogoMap: Record<string, string> = {
  Apple: `${baseUrl}brands/apple.svg`,
  Samsung: `${baseUrl}brands/samsung.svg`,
  Huawei: `${baseUrl}brands/huawei.svg`,
  Xiaomi: `${baseUrl}brands/xiaomi.svg`,
  OnePlus: `${baseUrl}brands/oneplus.svg`,
  Google: `${baseUrl}brands/google.svg`,
  Sony: `${baseUrl}brands/sony.svg`,
  Nokia: `${baseUrl}brands/nokia.svg`,
};
---
<section class="py-12 bg-slate-50 border-y border-slate-200">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-center text-sm font-medium text-slate-500 uppercase tracking-wider mb-6">{brands.headline}</h2>
    <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10">
      {brands.items.map((brand) => (
        <span class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:border-navy/30 hover:text-navy transition-colors">
          {brandLogoMap[brand] && (
            <img
              src={brandLogoMap[brand]}
              alt={`${brand} Logo`}
              class="h-5 w-auto object-contain"
              loading="lazy"
              decoding="async"
            />
          )}
          <span>{brand}</span>
        </span>
      ))}
    </div>
  </div>
</section>
