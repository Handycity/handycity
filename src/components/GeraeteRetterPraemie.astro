---
interface Props {
  data: {
    headline: string;
    subheadline: string;
    description: string;
    highlights: string[];
    ctaText: string;
    ctaHref: string;
    steps: { step: string; title: string; description: string }[];
  };
}
const { data } = Astro.props;
const bonusUrl = 'https://geräte-retter-prämie.at';

function linkifyBonusDomain(text: string): string {
  const escaped = text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');

  return escaped.replace(
    /geräte-retter-prämie\.at/g,
    `<a href="${bonusUrl}" target="_blank" rel="noopener noreferrer" class="font-medium text-green underline underline-offset-4 hover:text-green/80">geräte-retter-prämie.at</a>`
  );
}
---
<section id="geraete-retter-praemie" class="py-16 md:py-24 bg-green-light/30">
  <div class="max-w-7xl mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <span class="inline-flex items-center gap-2 text-sm font-semibold text-green bg-green/10 px-3 py-1 rounded-full mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        Geförderte Reparatur
      </span>
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-3">{data.headline}</h2>
      <p class="text-lg font-semibold text-green mb-4">{data.subheadline}</p>
      <p class="text-slate-600">{data.description}</p>
    </div>

    <!-- Highlights -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto mb-12">
      {data.highlights.map((h) => (
        <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-green/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span class="text-sm text-slate-700" set:html={linkifyBonusDomain(h)} />
        </div>
      ))}
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto mb-10">
      {data.steps.map((s) => (
        <div class="text-center">
          <div class="w-10 h-10 bg-green text-white rounded-full flex items-center justify-center font-bold mx-auto mb-3">
            {s.step}
          </div>
          <h3 class="font-semibold text-slate-800 mb-1">{s.title}</h3>
          <p class="text-sm text-slate-600" set:html={linkifyBonusDomain(s.description)} />
        </div>
      ))}
    </div>

    <div class="text-center">
      <a
        href={data.ctaHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-green text-white px-6 py-3 rounded-lg font-semibold hover:bg-green/90 transition-colors"
      >
        {data.ctaText}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </div>
</section>
