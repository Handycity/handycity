---
interface Props {
  hero: {
    headline: string;
    subheadline: string;
    ctaPrimary: { text: string; href: string };
    ctaSecondary: { text: string; href: string };
    trustBadges: { text: string }[];
  };
}
const { hero } = Astro.props;
---
<section class="relative bg-navy min-h-screen flex flex-col justify-center overflow-hidden">
  <img src={`${import.meta.env.BASE_URL}images/store-image-in.jpg`} alt="Handycity Geschäft innen" class="absolute inset-0 w-full h-full object-cover" />
  <div class="absolute inset-0 bg-gradient-to-br from-navy/90 via-navy-dark/85 to-navy/90"></div>
  <div class="relative max-w-7xl mx-auto px-4 text-center">
    <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-4">
      {hero.headline}
    </h1>
    <p class="text-lg md:text-xl text-slate-200 max-w-2xl mx-auto mb-8">
      {hero.subheadline}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href={hero.ctaPrimary.href}
        class="inline-flex items-center gap-2 bg-cyan text-white px-6 py-3 rounded-lg font-semibold text-lg hover:bg-cyan-light transition-colors w-full sm:w-auto justify-center"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {hero.ctaPrimary.text}
      </a>
      <a
        href={hero.ctaSecondary.href}
        class="inline-flex items-center gap-2 border-2 border-white/30 text-white px-6 py-3 rounded-lg font-semibold text-lg hover:bg-white/10 transition-colors w-full sm:w-auto justify-center"
      >
        {hero.ctaSecondary.text}
      </a>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6">
      {hero.trustBadges.map((badge) => (
        <span class="inline-flex items-center gap-2 text-sm text-slate-200 bg-white/10 px-4 py-2 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          {badge.text}
        </span>
      ))}
    </div>
  </div>

  <!-- Scroll-down arrow -->
  <a href="#services" class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/70 hover:text-white transition-colors" aria-label="Nach unten scrollen">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 animate-hero-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </a>
</section>

<style>
  @keyframes hero-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50% { transform: translateY(8px); opacity: 1; }
  }
  .animate-hero-bounce { animation: hero-bounce 2s ease-in-out infinite; }
</style>
