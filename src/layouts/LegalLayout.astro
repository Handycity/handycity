---
import '../styles/global.css';
import { readFileSync } from 'fs';
import yaml from 'js-yaml';

interface Props {
  title: string;
}

const { title } = Astro.props;
const raw = readFileSync('src/data/content.yaml', 'utf-8');
const content = yaml.load(raw) as Record<string, any>;
const { site, company } = content;
---
<!doctype html>
<html lang={site.language}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | {company.name}</title>
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
</head>
<body class="bg-white text-slate-800 font-sans antialiased">
  <!-- Simple header -->
  <header class="bg-white border-b border-slate-200">
    <div class="max-w-3xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 font-bold text-lg text-navy">
        <img src={`${import.meta.env.BASE_URL}images/handycity-logo.png`} alt="Handycity Logo" class="h-8 w-auto" />
      </a>
      <a href={import.meta.env.BASE_URL} class="text-sm text-slate-600 hover:text-navy transition-colors">← Zurück zur Startseite</a>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 py-12 md:py-20">
    <slot />
  </main>

  <footer class="border-t border-slate-200 bg-slate-50">
    <div class="max-w-3xl mx-auto px-4 py-6 text-center text-xs text-slate-500">
      © {new Date().getFullYear()} {company.legalName}. Alle Rechte vorbehalten. ·
      <a href={`${import.meta.env.BASE_URL}impressum`} class="hover:text-navy">Impressum</a> ·
      <a href={`${import.meta.env.BASE_URL}datenschutz`} class="hover:text-navy">Datenschutz</a>
    </div>
  </footer>
</body>
</html>
