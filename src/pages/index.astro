---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ServicesHub from '../components/ServicesHub.astro';
import PriceCalculator from '../components/PriceCalculator.astro';
import GeraeteRetterPraemie from '../components/GeraeteRetterPraemie.astro';
import Brands from '../components/Brands.astro';
import Trust from '../components/Trust.astro';
import Process from '../components/Process.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import WillhabenShop from '../components/WillhabenShop.astro';
import FAQ from '../components/FAQ.astro';
import Location from '../components/Location.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { fetchGoogleReviews } from '../lib/google-places-reviews';
import { loadContentSync } from '../lib/content-store.mjs';

const content = loadContentSync() as Record<string, any>;

let liveReviews = null;
try {
  liveReviews = await fetchGoogleReviews({
    apiKey: import.meta.env.GOOGLE_PLACES_API_KEY,
    placeId: import.meta.env.GOOGLE_PLACE_ID,
    placeQuery: `${content.company.name}, ${content.company.address.street}, ${content.company.address.zip} ${content.company.address.city}`,
    latitude: Number(content.company?.geo?.lat),
    longitude: Number(content.company?.geo?.lng),
    language: 'de',
    maxItems: 6,
  });
} catch (error) {
  console.error('Google reviews fetch failed:', error);
}

const reviewsData = liveReviews
  ? {
      ...content.reviews,
      ...liveReviews,
    }
  : content.reviews;

// Merge phone-expert prices (if present) into the calculator prices as enrichment/fallback
import fs from 'fs';
import path from 'path';
const phoneExpertPath = path.resolve('./src/data/phone-expert/prices.json');
let phoneExpertPrices = [];
try {
  if (fs.existsSync(phoneExpertPath)) {
    phoneExpertPrices = JSON.parse(fs.readFileSync(phoneExpertPath, 'utf8'));
  }
} catch (err) {
  console.error('phone-expert load failed:', err?.message || err);
}

const mergedCalculator = {
  ...content.calculator,
  prices: Array.isArray(content.calculator?.prices) ? [...content.calculator.prices] : [],
};
if (phoneExpertPrices.length) {
  // add phone-expert entries that are not already present (by brand+device+repair)
  const key = (p) => `${p.brand}||${p.device}||${p.repair}`;
  const existing = new Set(mergedCalculator.prices.map(key));
  for (const p of phoneExpertPrices) {
    if (!existing.has(key(p))) mergedCalculator.prices.push(p);
  }
}
---
<Layout>
  <Header company={content.company} />
  <main id="main">
    <Hero hero={content.hero} company={content.company} hours={content.hours} />
    <TrustBar trustBar={content.trustBar} reviews={reviewsData} />

    <ServicesHub services={content.services} />
    <Process process={content.process} />
    <PriceCalculator calculator={content.calculator} />

    <GeraeteRetterPraemie data={content.geraeteRetterPraemie} />
    <Trust trust={content.trust} />
    <WillhabenShop willhaben={content.willhaben} />
    <GoogleReviews reviews={reviewsData} />
    <FAQ faq={content.faq} />
    <Contact contact={content.contact} company={content.company} />
    <Location company={content.company} hours={content.hours} />
    <Brands brands={content.brands} />
  </main>
  <Footer company={content.company} social={content.social} />
</Layout>
