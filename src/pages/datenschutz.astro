---
import LegalLayout from '../layouts/LegalLayout.astro';
import { loadContentSync } from '../lib/content-store.mjs';

const content = loadContentSync() as Record<string, any>;
const { datenschutz } = content;
---
<LegalLayout title={datenschutz.headline}>
  <h1 class="text-2xl md:text-3xl font-bold text-navy mb-8">{datenschutz.headline}</h1>
  <div class="text-slate-600 leading-relaxed whitespace-pre-line">
    {datenschutz.content}
  </div>
</LegalLayout>
