---
import LegalLayout from '../layouts/LegalLayout.astro';
import { readFileSync } from 'fs';
import yaml from 'js-yaml';

const raw = readFileSync('src/data/content.yaml', 'utf-8');
const content = yaml.load(raw) as Record<string, any>;
const { impressum } = content;
---
<LegalLayout title={impressum.headline}>
  <h1 class="text-2xl md:text-3xl font-bold text-navy mb-8">{impressum.headline}</h1>
  <div class="text-slate-600 leading-relaxed whitespace-pre-line">
    {impressum.content}
  </div>
</LegalLayout>
